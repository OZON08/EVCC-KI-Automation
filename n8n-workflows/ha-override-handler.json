{
  "name": "Battery AI – HA Override Handler",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "battery-ai-override",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook: HA Override",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300],
      "webhookId": "battery-ai-override",
      "notes": "HA sendet POST mit Body: { \"event\": \"ai_control_disabled\" | \"ai_control_enabled\" | \"discharge_enabled\" | \"discharge_disabled\" }"
    },
    {
      "parameters": {
        "jsCode": "const event = $input.item.json?.body?.event ?? $input.item.json?.event ?? '';\nreturn [{ json: { event } }];"
      },
      "id": "extract-event",
      "name": "Event lesen",
      "type": "n8n-nodes-base.code",
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.event }}",
              "operation": "equals",
              "value2": "ai_control_disabled"
            }
          ]
        }
      },
      "id": "if-disable",
      "name": "KI deaktiviert?",
      "type": "n8n-nodes-base.if",
      "position": [680, 180]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.event }}",
              "operation": "equals",
              "value2": "ai_control_enabled"
            }
          ]
        }
      },
      "id": "if-enable",
      "name": "KI aktiviert?",
      "type": "n8n-nodes-base.if",
      "position": [680, 340]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.event }}",
              "operation": "equals",
              "value2": "discharge_enabled"
            }
          ]
        }
      },
      "id": "if-discharge-on",
      "name": "Einspeisen aktiviert?",
      "type": "n8n-nodes-base.if",
      "position": [680, 500]
    },
    {
      "parameters": {
        "method": "DELETE",
        "url": "https://laden.willeke.local/api/batterygridchargelimit",
        "authentication": "none",
        "options": {}
      },
      "id": "evcc-disable-charging",
      "name": "evcc: Netzladen aus",
      "type": "n8n-nodes-base.httpRequest",
      "position": [920, 120],
      "notes": "KI deaktiviert: Netzladen sofort stoppen"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api-workflow.willeke.local/api/v1/workflows/DAILY-OPTIMIZER-ID/execute",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-API-KEY",
              "value": "DEIN-N8N-API-KEY"
            }
          ]
        },
        "options": {}
      },
      "id": "trigger-optimizer",
      "name": "Daily Optimizer starten",
      "type": "n8n-nodes-base.httpRequest",
      "position": [920, 280],
      "notes": "DAILY-OPTIMIZER-ID und N8N-API-KEY nach Import ersetzen"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://laden.willeke.local/api/batterydischargecontrol/true",
        "authentication": "none",
        "options": {}
      },
      "id": "evcc-discharge-on",
      "name": "evcc: Entladen aktivieren",
      "type": "n8n-nodes-base.httpRequest",
      "position": [920, 440]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://laden.willeke.local/api/batterydischargecontrol/false",
        "authentication": "none",
        "options": {}
      },
      "id": "evcc-discharge-off",
      "name": "evcc: Entladen deaktivieren",
      "type": "n8n-nodes-base.httpRequest",
      "position": [920, 580]
    }
  ],
  "connections": {
    "Webhook: HA Override": {
      "main": [[{ "node": "Event lesen", "type": "main", "index": 0 }]]
    },
    "Event lesen": {
      "main": [[
        { "node": "KI deaktiviert?", "type": "main", "index": 0 },
        { "node": "KI aktiviert?", "type": "main", "index": 0 },
        { "node": "Einspeisen aktiviert?", "type": "main", "index": 0 }
      ]]
    },
    "KI deaktiviert?": {
      "main": [
        [{ "node": "evcc: Netzladen aus", "type": "main", "index": 0 }],
        []
      ]
    },
    "KI aktiviert?": {
      "main": [
        [{ "node": "Daily Optimizer starten", "type": "main", "index": 0 }],
        []
      ]
    },
    "Einspeisen aktiviert?": {
      "main": [
        [{ "node": "evcc: Entladen aktivieren", "type": "main", "index": 0 }],
        [{ "node": "evcc: Entladen deaktivieren", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "description": "Reagiert auf HA-Schalter-Events via Webhook. IF-Nodes statt Switch fuer maximale Kompatibilitaet.",
    "version": "2.0.0"
  }
}
